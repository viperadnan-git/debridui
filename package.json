{
    "name": "debridui",
    "version": "0.1.0",
    "private": true,
    "license": "GPL-3.0-or-later",
    "author": "Adnan Ahmad <viperadnan@gmail.com>",
    "description": "A modern debrid client with built-in media discovery and streaming.",
    "keywords": [
        "debrid",
        "client",
        "nextjs",
        "tailwindcss",
        "typescript"
    ],
    "homepage": "https://debridui.viperadnan.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/viperadnan-git/debridui"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "node .next/standalone/server.js",
        "postbuild": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
        "lint": "biome lint",
        "lint:fix": "biome lint --write",
        "format": "biome format --write",
        "format:check": "biome format",
        "check": "biome check",
        "check:fix": "biome check --write",
        "typecheck": "tsc --noEmit",
        "verify": "bun run typecheck && bun run check",
        "update": "bunx next upgrade && bun update",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@bprogress/next": "^3.2.12",
        "@hookform/resolvers": "^5.2.2",
        "@tanstack/react-query": "^5.100.10",
        "@tanstack/react-query-persist-client": "^5.100.10",
        "better-auth": "^1.6.11",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "drizzle-orm": "^0.45.2",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "embla-carousel-wheel-gestures": "^8.1.0",
        "fuse.js": "^7.3.0",
        "idb-keyval": "^6.2.2",
        "lucide-react": "^0.539.0",
        "next": "16.2.6",
        "next-themes": "^0.4.6",
        "postgres": "^3.4.9",
        "radix-ui": "^1.4.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-dropzone": "^14.4.1",
        "react-hook-form": "^7.75.0",
        "react-window": "^1.8.11",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "uuid": "^13.0.2",
        "vaul": "^1.1.2",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^20.19.41",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/react-window": "^1.8.8",
        "drizzle-kit": "^0.31.10",
        "shadcn": "^3.8.5",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3"
    },
    "nizm": {
        "hooks": {
            "biome": {
                "cmd": "bunx biome check --write --no-errors-on-unmatched {staged_files}"
            },
            "lint": {
                "cmd": "bun run lint"
            }
        }
    },
    "overrides": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3"
    }
}
